@article{bertrand_network_2000,
	title = {Network {Effects} and {Welfare} {Cultures}*},
	volume = {115},
	issn = {0033-5533},
	url = {https://doi.org/10.1162/003355300554971},
	doi = {10.1162/003355300554971},
	abstract = {We empirically examine the role of social networks in welfare participation using data on language spoken at home to better infer networks within an area. Our empirical strategy asks whether being surrounded by others who speak the same language increases welfare use more for those from high welfare-using language groups. This methodology allows us to include local area and language group fixed effects and to control for the direct effect of being surrounded by one's language group; these controls eliminate many ofthe problems in previous studies. The results strongly confirm the importance of networks in welfare participation.},
	number = {3},
	urldate = {2026-03-14},
	journal = {The Quarterly Journal of Economics},
	author = {Bertrand, Marianne and Luttmer, Erzo F. P. and Mullainathan, Sendhil},
	month = aug,
	year = {2000},
	pages = {1019--1055},
	file = {Snapshot:C\:\\Users\\qiann\\Zotero\\storage\\P72T2WC7\\003355300554971.html:text/html},
}
